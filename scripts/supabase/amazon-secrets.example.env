# Copy values from Amazon Seller Central Developer Console + Supabase dashboard.
# DO NOT commit real values. Apply with:
#   Get-Content scripts/supabase/amazon-secrets.example.env | ForEach-Object {
#     if ($_ -match '^([^#=]+)=(.+)$') { supabase secrets set "$($Matches[1])=$($Matches[2])" }
#   }
#
# Minimum for Connect Amazon (OAuth):
# AMAZON_APP_ID=
# AMAZON_LWA_CLIENT_ID=        # From SPP app → View LWA credentials (NOT developer.amazon.com profile unless same)
# AMAZON_LWA_CLIENT_SECRET=
# AMAZON_AUTH_REDIRECT_URI=https://yxdzvzscufkvewecvagq.supabase.co/functions/v1/amazon-auth-callback
# AMAZON_SP_API_REGION=na
# AMAZON_DEFAULT_MARKETPLACE_ID=ATVPDKIKX0DER
# AMAZON_OAUTH_VERSION=beta          # Draft app only (Seller Central → Develop Apps)
# AMAZON_OAUTH_VERSION=production    # Published app — omit version=beta in consent URL
#
# For live SP-API sync / patch / submit (after OAuth works):
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AMAZON_IAM_ROLE_ARN=arn:aws:iam::123456789012:role/SellingPartnerAPIRole
# AWS_SESSION_TOKEN=
# AMAZON_ENABLE_LIVE_PATCH=false
# AMAZON_ENABLE_LIVE_SUBMIT=false
# AMAZON_ENABLE_VALIDATION_PREVIEW=false
